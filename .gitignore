# iteration scratch: the /bin/cp backup taken before a big swing, and the ad-hoc
# probe/shot scripts an iteration writes to verify itself. Ignored so a killed
# iteration's leftovers can't make run-loop.sh refuse to start on a "dirty" tree.
before.html
probe-*.mjs
shot-*.mjs
